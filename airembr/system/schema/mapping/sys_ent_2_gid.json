{
  "table": "sys_ent_2_gid",
  "distributed": "HASH(entity_pk)",
  "pk": "entity_pk",
  "engine": "olap",
  "properties": [
    "\"enable_persistent_index\" = \"true\""
  ],
  "indexes": [
    {
      "index_name": "idx_pk",
      "columns": [
        "entity_pk"
      ],
      "type": "BITMAP"
    },
    {
      "index_name": "idx_gid",
      "columns": [
        "entity_gid"
      ],
      "type": "BITMAP"
    }
  ],
  "columns": [
    {
      "column": "entity_pk",
      "sr_column_type": "varchar(48)",
      "ddb_column_type": "VARCHAR",
      "property": "entity.pk",
      "default": "NOT NULL"
    },
    {
      "column": "entity_gid",
      "sr_column_type": "varchar(48)",
      "ddb_column_type": "VARCHAR",
      "property": "entity.gid",
      "default": "NOT NULL"
    },
    {
      "column": "entity_type",
      "sr_column_type": "varchar(64)",
      "ddb_column_type": "VARCHAR",
      "property": "entity.type",
      "default": "NOT NULL"
    },
    {
      "column": "entity_gid_type",
      "sr_column_type": "varchar(64)",
      "ddb_column_type": "VARCHAR",
      "property": "entity.gid_type",
      "default": "NULL",
      "comment": "Entity identification id type. Describes how gid was build, for example: email, phone, username, etc."
    },
    {
      "column": "ts",
      "sr_column_type": "datetime",
      "ddb_column_type": "TIMESTAMP",
      "property": "ts",
      "default": "NOT NULL",
      "default_value": "CURRENT_TIMESTAMP"
    }
  ]
}
